{% extends 'base.html.twig' %}

{% block title %}Inloggen{% endblock %}

{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h1 class="h4 mb-0"><i class="bi bi-box-arrow-in-right"></i> Inloggen</h1>
            </div>
            <div class="card-body">
                {% if error %}
                    <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
                {% endif %}

                <form method="post">
                    <div class="mb-3">
                        <label for="username" class="form-label">E-mailadres</label>
                        <input type="email" id="username" name="_username" class="form-control" value="{{ last_username }}" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label for="password" class="form-label">Wachtwoord</label>
                        <input type="password" id="password" name="_password" class="form-control" required>
                    </div>
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                    <button type="submit" class="btn btn-primary w-100">Inloggen</button>
                </form>
                <p class="mt-3 mb-0 text-center">
                    Nog geen account? <a href="{{ path('app_register') }}">Registreren</a>
                </p>
            </div>
        </div>
    </div>
</div>
{% endblock %}
