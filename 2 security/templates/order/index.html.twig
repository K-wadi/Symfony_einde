{% extends 'base.html.twig' %}

{% block title %}Bestellingen{% endblock %}

{% block body %}
<h1 class="h3 mb-3"><i class="bi bi-cart"></i> Bestellingen</h1>
<p class="text-muted">Deze pagina is alleen zichtbaar voor gebruikers met <code>ROLE_ADMIN</code> (opdracht 3.3).</p>

<div class="card shadow-sm">
    <ul class="list-group list-group-flush">
        {% for order in orders %}
            <li class="list-group-item d-flex justify-content-between">
                <span>{{ order.description }}</span>
                <span class="text-muted">{{ order.orderedAt|date('d-m-Y H:i') }}</span>
            </li>
        {% else %}
            <li class="list-group-item text-muted">Geen bestellingen in de database.</li>
        {% endfor %}
    </ul>
</div>
{% endblock %}
