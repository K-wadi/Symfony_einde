{% extends 'base.html.twig' %}

{% block title %}Boeken beheer{% endblock %}

{% block body %}
<h1 class="h3 mb-3">Boeken (admin)</h1>
<div class="card shadow-sm">
    <table class="table mb-0">
        <thead class="table-primary">
        <tr>
            <th>Titel</th>
            <th>Auteur</th>
            <th class="text-end">Actie</th>
        </tr>
        </thead>
        <tbody>
        {% for book in books %}
            <tr>
                <td>{{ book.title }}</td>
                <td>{{ book.author.name }}</td>
                <td class="text-end">
                    <form method="post" action="{{ path('app_admin_book_delete', {id: book.id}) }}" onsubmit="return confirm('Boek verwijderen?');" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_book' ~ book.id) }}">
                        <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
