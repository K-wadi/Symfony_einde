{% extends 'base.html.twig' %}

{% block title %}Boeken{% endblock %}

{% block body %}
<h1 class="h3 mb-3"><i class="bi bi-book"></i> Boeken met auteur</h1>
<p class="text-muted">Overzicht voor gewone gebruikers (ROLE_USER) – opdracht 4.</p>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-primary">
            <tr>
                <th>Titel</th>
                <th>Auteur</th>
            </tr>
            </thead>
            <tbody>
            {% for book in books %}
                <tr>
                    <td>{{ book.title }}</td>
                    <td>{{ book.author.name }}</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
