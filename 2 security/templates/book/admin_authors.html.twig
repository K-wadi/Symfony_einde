{% extends 'base.html.twig' %}

{% block title %}Auteurs beheer{% endblock %}

{% block body %}
<h1 class="h3 mb-3">Auteurs (admin)</h1>
<div class="card shadow-sm">
    <table class="table mb-0">
        <thead class="table-primary">
        <tr>
            <th>Naam</th>
            <th class="text-end">Actie</th>
        </tr>
        </thead>
        <tbody>
        {% for author in authors %}
            <tr>
                <td>{{ author.name }}</td>
                <td class="text-end">
                    <form method="post" action="{{ path('app_admin_author_delete', {id: author.id}) }}" onsubmit="return confirm('Auteur en gekoppelde boeken verwijderen?');" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_author' ~ author.id) }}">
                        <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                    </form>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
