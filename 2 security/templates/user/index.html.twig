{% extends 'base.html.twig' %}

{% block title %}Gebruikers{% endblock %}

{% block body %}
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0"><i class="bi bi-people"></i> Gebruikers</h1>
    <a href="{{ path('app_user_add') }}" class="btn btn-success">
        <i class="bi bi-person-plus"></i> Gebruiker toevoegen
    </a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped mb-0">
            <thead class="table-primary">
            <tr>
                <th>Nr</th>
                <th>Voornaam</th>
                <th>Achternaam</th>
                <th>E-mail</th>
                <th>Geboortedatum</th>
                <th>Rollen</th>
                <th class="text-end">Actie</th>
            </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr>
                    <td>{{ loop.index }}</td>
                    <td>{{ user.firstName }}</td>
                    <td>{{ user.lastName }}</td>
                    <td>{{ user.email }}</td>
                    <td>{{ user.dateOfBirth|date('d-m-Y') }}</td>
                    <td>
                        {% for role in user.roles %}
                            <span class="badge bg-secondary">{{ role }}</span>
                        {% endfor %}
                    </td>
                    <td class="text-end">
                        <form method="post" action="{{ path('app_user_delete', {id: user.id}) }}" onsubmit="return confirm('Gebruiker verwijderen?');" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_user' ~ user.id) }}">
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="7" class="text-center text-muted py-4">Geen gebruikers.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
