{% extends 'base.html.twig' %}
{% block title %}Patiënt home{% endblock %}
{% block body %}
<h1 class="h3">Welkom, {{ app.user.fullName }}</h1>
<p class="text-muted">Homepage patiënt (ROLE_PATIENT)</p>

{% if notifications is not empty %}
<div class="alert alert-info">
    <h2 class="h6">Berichten over je afspraken</h2>
    <ul class="mb-0">
        {% for n in notifications %}
            <li>{{ n.message }} <small class="text-muted">({{ n.createdAt|date('d-m-Y H:i') }})</small></li>
        {% endfor %}
    </ul>
</div>
{% endif %}

<h2 class="h5 mt-4">Nieuws van het ziekenhuis</h2>
{% for item in newsItems %}
    <div class="card mb-2 shadow-sm">
        <div class="card-body">
            <h3 class="h6">{{ item.title }}</h3>
            <p class="mb-0">{{ item.body }}</p>
            <small class="text-muted">{{ item.publishedAt|date('d-m-Y') }}</small>
        </div>
    </div>
{% else %}
    <p class="text-muted">Nog geen nieuwsberichten.</p>
{% endfor %}
{% endblock %}
