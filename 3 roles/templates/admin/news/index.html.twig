{% extends 'base.html.twig' %}
{% block title %}Nieuws{% endblock %}
{% block body %}
<div class="d-flex justify-content-between mb-3">
    <h1 class="h3">Nieuwsberichten</h1>
    <a href="{{ path('app_admin_news_new') }}" class="btn btn-success">Publiceren</a>
</div>
{% for item in newsItems %}
    <div class="card mb-2 shadow-sm">
        <div class="card-body d-flex justify-content-between">
            <div>
                <h2 class="h6">{{ item.title }}</h2>
                <p class="mb-0">{{ item.body }}</p>
            </div>
            <form method="post" action="{{ path('app_admin_news_delete', {id: item.id}) }}" onsubmit="return confirm('Verwijderen?');">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_news' ~ item.id) }}">
                <button class="btn btn-sm btn-danger">Verwijderen</button>
            </form>
        </div>
    </div>
{% endfor %}
{% endblock %}
