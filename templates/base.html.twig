<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Je haar zit goed{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('styles/kapsalon.css') }}">
    {% if app.session.get('cookie_consent') == 'all' %}
    <script async src="https://www.googletagmanager.com/gtag/js?id={{ google_analytics_id }}"></script>
    <script>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','{{ google_analytics_id }}');</script>
    {% endif %}
    {% block stylesheets %}{% endblock %}
</head>
<body>
<nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom border-olive shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold text-olive" href="{{ path('app_home') }}">
            <i class="bi bi-scissors me-1"></i> Je haar zit goed
        </a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav" aria-controls="nav" aria-expanded="false" aria-label="Menu">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div id="nav" class="collapse navbar-collapse">
            <ul class="navbar-nav me-auto">
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') == 'app_home' ? 'active' : '' }}" href="{{ path('app_home') }}">Home</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') == 'kapsalon_treatments' ? 'active' : '' }}" href="{{ path('kapsalon_treatments') }}">Behandelingen</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') == 'kapsalon_products' ? 'active' : '' }}" href="{{ path('kapsalon_products') }}">Producten</a></li>
                <li class="nav-item"><a class="nav-link {{ app.request.attributes.get('_route') == 'kapsalon_contact' ? 'active' : '' }}" href="{{ path('kapsalon_contact') }}">Contact</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('kapsalon_subscription') }}">Abonnement</a></li>
                <li class="nav-item">
                    <a class="nav-link position-relative {{ app.request.attributes.get('_route') starts with 'kapsalon_cart' ? 'active' : '' }}" href="{{ path('kapsalon_cart') }}">
                        <i class="bi bi-bag"></i> Winkelwagen
                    </a>
                </li>
            </ul>
            <ul class="navbar-nav align-items-lg-center gap-lg-1">
                {% if app.user %}
                    <li class="nav-item"><span class="nav-link small"><i class="bi bi-person-circle me-1"></i>{{ app.user.displayName }}</span></li>
                    {% if is_granted('ROLE_OWNER') %}
                        <li class="nav-item"><a class="nav-link" href="{{ path('kapsalon_admin_dashboard') }}">Admin</a></li>
                    {% endif %}
                    {% if is_granted('ROLE_EMPLOYEE') %}
                        <li class="nav-item"><a class="nav-link" href="{{ path('kapsalon_staff_dashboard') }}">Medewerker</a></li>
                    {% endif %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_logout') }}">Uitloggen</a></li>
                {% else %}
                    <li class="nav-item"><a class="btn btn-olive btn-sm ms-lg-2" href="{{ path('app_login') }}">Inloggen</a></li>
                {% endif %}
            </ul>
        </div>
    </div>
</nav>

<main class="container py-4 py-lg-5">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ label == 'error' ? 'danger' : label }} alert-dismissible fade show shadow-sm" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Sluiten"></button>
            </div>
        {% endfor %}
    {% endfor %}
    {% block body %}{% endblock %}
</main>

<footer class="bg-dark text-white py-4 mt-auto border-top border-olive">
    <div class="container">
        <div class="row g-3 align-items-center">
            <div class="col-md-6">
                <strong class="text-olive">Je haar zit goed</strong>
                <p class="small mb-0 opacity-75">IEDERE DAG MOOI — persoonlijk advies en trendy kapsels.</p>
            </div>
            <div class="col-md-6 text-md-end small">
                <a class="text-white me-2" href="{{ path('kapsalon_privacy') }}">Privacy</a>
                <a class="text-white me-2" href="{{ path('kapsalon_terms') }}">Voorwaarden</a>
                <a class="text-white me-2" href="{{ path('kapsalon_cookie_settings') }}">Cookies</a>
                <a class="text-white" href="{{ path('kapsalon_contact') }}">Contact</a>
            </div>
        </div>
        <hr class="border-secondary my-3">
        <p class="small mb-0 text-center opacity-75">&copy; {{ 'now'|date('Y') }} Je haar zit goed</p>
    </div>
</footer>

{% if app.session.get('cookie_consent') is null %}
<div class="cookie-banner p-3 bg-dark text-white border-top border-olive">
    <div class="container d-flex flex-wrap align-items-center gap-3 justify-content-between">
        <span class="small"><i class="bi bi-cookie me-1"></i> Deze site gebruikt cookies om uw browse-ervaring te verbeteren.</span>
        <div class="d-flex gap-2 flex-wrap">
            <a href="{{ path('kapsalon_cookie_settings') }}" class="btn btn-outline-light btn-sm">Instellingen</a>
            <form action="{{ path('kapsalon_cookies_save') }}" method="post" class="d-flex gap-2">
                <button class="btn btn-outline-light btn-sm" type="submit" name="cookie_choice" value="essential">Alleen noodzakelijk</button>
                <button class="btn btn-olive btn-sm" type="submit" name="cookie_choice" value="all">Alles accepteren</button>
            </form>
        </div>
    </div>
</div>
{% endif %}

<button type="button" class="btn btn-olive fab-reserve position-fixed bottom-0 end-0 m-4 shadow-lg" data-bs-toggle="modal" data-bs-target="#reserveModal">
    <i class="bi bi-calendar-plus me-1"></i> Afspraak maken
</button>

<div class="modal fade" id="reserveModal" tabindex="-1" aria-labelledby="reserveModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="reserveModalLabel"><i class="bi bi-calendar-check me-2"></i>Reserveren</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Sluiten"></button>
            </div>
            <div class="modal-body p-4">
                {{ render(controller('App\\Controller\\AppointmentController::bookModal')) }}
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
