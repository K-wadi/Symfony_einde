{% extends 'base.html.twig' %}
{% block title %}Inloggen{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-md-5 col-lg-4">
        <div class="content-card p-4 shadow">
            <div class="text-center mb-4">
                <i class="bi bi-scissors text-olive display-4"></i>
                <h1 class="h3 mt-2">Inloggen</h1>
                <p class="text-muted small">Eigenaresse of medewerker</p>
            </div>
            {% if error %}
                <div class="alert alert-danger">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
            {% endif %}
            <form method="post" data-turbo="false">
                <div class="mb-3">
                    <label for="inputEmail" class="form-label">E-mailadres</label>
                    <input type="email" value="{{ last_username }}" name="_username" id="inputEmail" class="form-control form-control-lg" autocomplete="email" required autofocus>
                </div>
                <div class="mb-4">
                    <label for="inputPassword" class="form-label">Wachtwoord</label>
                    <input type="password" name="_password" id="inputPassword" class="form-control form-control-lg" autocomplete="current-password" required>
                </div>
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
                <button class="btn btn-olive w-100 btn-lg" type="submit">Inloggen</button>
            </form>
            <p class="text-center mt-3 mb-0 small"><a href="{{ path('app_home') }}">Terug naar website</a></p>
        </div>
    </div>
</div>
{% endblock %}
