{% extends 'base.html.twig' %}
{% block title %}Contact{% endblock %}
{% block body %}
<div class="row g-4">
    <div class="col-lg-5">
        {% include 'kapsalon/_partials/page_header.html.twig' with {
            title: 'Contact',
            subtitle: 'Vragen of een afspraak? Stuur ons een bericht.'
        } only %}
        <div class="content-card p-4">
            <p class="mb-2"><i class="bi bi-envelope text-olive me-2"></i>jehaarzitgoed@kapper.nl</p>
            <p class="mb-0"><i class="bi bi-telephone text-olive me-2"></i>Bel ons voor een afspraak</p>
        </div>
    </div>
    <div class="col-lg-7">
        <div class="content-card p-4">
            {{ form_start(form, { attr: { class: 'needs-validation' } }) }}
            {{ form_row(form.name) }}
            {{ form_row(form.email) }}
            {{ form_row(form.message) }}
            <button class="btn btn-olive" type="submit"><i class="bi bi-send me-1"></i>Versturen</button>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
