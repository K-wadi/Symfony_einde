{% extends 'kapsalon/admin/_layout.html.twig' %}
{% block admin_content %}
{% include 'kapsalon/_partials/page_header.html.twig' with { title: 'Afspraak bewerken' } only %}
<div class="content-card p-4 col-lg-6">
<form method="post" class="row g-3">
<div class="col-12"><label class="form-label">Naam</label><input name="customerName" value="{{ appointment.customerName }}" class="form-control" required></div>
<div class="col-12"><label class="form-label">Datum/tijd</label><input name="startsAt" type="datetime-local" value="{{ appointment.startsAt|date('Y-m-d\\TH:i') }}" class="form-control" required></div>
<div class="col-12"><button class="btn btn-olive" type="submit">Opslaan</button></div>
</form>
</div>
{% endblock %}
