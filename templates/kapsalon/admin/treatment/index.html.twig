{% extends 'kapsalon/admin/_layout.html.twig' %}
{% block admin_content %}
{% include 'kapsalon/_partials/page_header.html.twig' with {
    title: 'Behandelingen',
    actions: '<a href="' ~ path('kapsalon_admin_treatment_new') ~ '" class="btn btn-olive">Toevoegen</a>'
} only %}
<div class="table-card">
<table class="table table-hover mb-0">
<thead><tr><th>Naam</th><th>Duur</th><th>Prijs</th></tr></thead>
<tbody>
{% for t in treatments %}
<tr><td>{{ t.name }}</td><td>{{ t.durationMinutes }} min</td><td>€ {{ t.priceFormatted }}</td></tr>
{% endfor %}
</tbody>
</table>
</div>
{% endblock %}
