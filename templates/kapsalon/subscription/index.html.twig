{% extends 'base.html.twig' %}
{% block title %}Knipabonnement{% endblock %}
{% block body %}
{% include 'kapsalon/_partials/page_header.html.twig' with { title: 'Knipabonnement', subtitle: 'Vaste prijs, vaste verzorging — vraag uw abonnement aan.' } only %}

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card h-100 border-olive">
            <div class="card-body">
                <h3 class="h5">Basis</h3>
                <p class="text-muted">4 bezoeken per jaar</p>
                <p class="fs-4 fw-bold text-olive mb-0">€ 99,00</p>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <h3 class="h5">Premium</h3>
                <p class="text-muted">8 bezoeken per jaar</p>
                <p class="fs-4 fw-bold text-olive mb-0">€ 199,00</p>
            </div>
        </div>
    </div>
</div>

<div class="content-card p-4 col-lg-6 mx-auto">
    {{ form_start(form) }}
    {{ form_row(form.customerName) }}
    {{ form_row(form.customerEmail) }}
    {{ form_row(form.planName) }}
    {{ form_row(form.submit, { attr: { class: 'btn btn-olive w-100' } }) }}
    {{ form_end(form) }}
</div>
{% endblock %}
