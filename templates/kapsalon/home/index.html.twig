{% extends 'base.html.twig' %}

{% block title %}Home — Je haar zit goed{% endblock %}

{% block body %}
<section class="hero mb-5">
    <div class="row align-items-center">
        <div class="col-lg-8">
            <p class="text-uppercase small mb-2 opacity-75">Kapsalon in de regio</p>
            <h1 class="display-5 fw-bold">Je haar zit goed</h1>
            <p class="lead mb-3">IEDERE DAG MOOI — wij maken mensen letterlijk en figuurlijk mooier.</p>
            <p class="mb-4">Persoonlijk advies, trendy kapsels voor vrouwen 15–45, ontspanning in de zaak.</p>
            <a href="{{ path('kapsalon_contact') }}" class="btn btn-olive btn-lg me-2"><i class="bi bi-envelope me-1"></i>Contact</a>
            <button type="button" class="btn btn-outline-light btn-lg" data-bs-toggle="modal" data-bs-target="#reserveModal"><i class="bi bi-calendar-plus me-1"></i>Reserveren</button>
        </div>
    </div>
</section>

<section class="mb-5">
    <h2 class="section-title text-olive">Onze specialisatie</h2>
    <p class="content-card p-4 mb-0">Trendy knippen, kleuren, Olaplex en Kérastase. Persoonlijk advies dat bij jouw haartype past.</p>
</section>

<section class="mb-5 salon-gallery">
    <h2 class="section-title text-olive">Impressie salon</h2>
    <div class="row g-3">
        {% for img, label in {'salon1.svg':'Salon','salon2.svg':'Knippen','salon3.svg':'Kleuren','salon4.svg':'Styling'} %}
        <div class="col-6 col-md-3">
            <img src="{{ asset('images/salon/' ~ img) }}" alt="{{ label }}" class="img-fluid rounded shadow-sm">
        </div>
        {% endfor %}
    </div>
</section>

<p class="small text-muted mb-5"><i class="bi bi-type me-1"></i>Lettertype: Segoe UI (afgestemd met klant).</p>

<section class="mb-5">
    <h2 class="section-title">Voor jou</h2>
    <div class="row g-3">
        {% for offer in personal_offers %}
        <div class="col-md-4">
            <div class="card card-offer h-100">
                <div class="card-body">
                    <span class="badge bg-olive text-white mb-2">Persoonlijk</span>
                    <h5 class="card-title">{{ offer.title }}</h5>
                    <p class="card-text text-muted">{{ offer.description }}</p>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-12"><p class="text-muted content-card p-4 mb-0">Bestel of reserveer om persoonlijke aanbiedingen te zien.</p></div>
        {% endfor %}
    </div>
</section>

<section class="mb-5">
    <h2 class="section-title">Aanbiedingen</h2>
    <div class="row g-3">
        {% for offer in offers %}
        <div class="col-md-4">
            <div class="card card-offer h-100">
                <div class="card-body">
                    <h5 class="card-title">{{ offer.title }}</h5>
                    <p class="card-text">{{ offer.description }}</p>
                </div>
            </div>
        </div>
        {% else %}
        <div class="col-12"><p class="text-muted">Geen actieve aanbiedingen.</p></div>
        {% endfor %}
    </div>
</section>

<section class="mb-5">
    <h2 class="section-title">Behandelingen</h2>
    <div class="row g-3 mb-3">
        {% for t in treatments %}
        <div class="col-sm-6 col-lg-3">
            <div class="card h-100 text-center">
                <div class="card-body">
                    <i class="bi bi-scissors text-olive fs-3 mb-2 d-block"></i>
                    <h6 class="card-title">{{ t.name }}</h6>
                    <p class="small text-muted mb-0">{{ t.durationMinutes }} min · € {{ t.priceFormatted }}</p>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
    <a href="{{ path('kapsalon_treatments') }}" class="btn btn-outline-olive">Alle behandelingen <i class="bi bi-arrow-right"></i></a>
</section>

<section class="content-card p-4 d-flex flex-wrap align-items-center justify-content-between gap-3">
    <div>
        <h2 class="h4 mb-1">Producten voor thuis</h2>
        <p class="text-muted mb-0">Kérastase en meer — ophalen in de winkel.</p>
    </div>
    <a href="{{ path('kapsalon_products') }}" class="btn btn-olive">Naar webwinkel</a>
</section>
{% endblock %}
