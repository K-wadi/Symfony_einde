{% extends 'base.html.twig' %}
{% block title %}Klant registreren{% endblock %}
{% block body %}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow border-primary">
            <div class="card-header bg-primary text-white text-center py-3">
                <h1 class="h4 mb-0"><i class="bi bi-person-plus"></i> Klant registreren</h1>
            </div>
            <div class="card-body p-4">
                {{ form_start(form, { attr: { class: 'customer-form' } }) }}
                <div class="mb-3">
                    {{ form_label(form.firstName, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                    {{ form_widget(form.firstName, { attr: { class: 'form-control form-control-lg' } }) }}
                    {{ form_errors(form.firstName) }}
                    {% if form.firstName.vars.help %}<div class="form-text">{{ form.firstName.vars.help }}</div>{% endif %}
                </div>
                <div class="mb-3">
                    {{ form_label(form.lastName, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                    {{ form_widget(form.lastName, { attr: { class: 'form-control form-control-lg' } }) }}
                    {{ form_errors(form.lastName) }}
                </div>
                <div class="mb-4">
                    {{ form_label(form.email, null, { label_attr: { class: 'form-label fw-semibold' } }) }}
                    {{ form_widget(form.email, { attr: { class: 'form-control form-control-lg', placeholder: 'naam@voorbeeld.nl' } }) }}
                    {{ form_errors(form.email) }}
                    {% if form.email.vars.help %}<div class="form-text">{{ form.email.vars.help }}</div>{% endif %}
                </div>
                {{ form_widget(form.save) }}
                {{ form_end(form) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
