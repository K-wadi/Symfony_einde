{% extends 'base.html.twig' %}
{% block title %}Book - Author{% endblock %}
{% block body %}
<h1 class="h3">showInformation – Books &amp; Authors</h1>
<p class="text-muted">Opdracht 1.3: foreach met gekoppelde relaties (geen vreemde sleutels, wel entity collections).</p>

<div class="row">
    <div class="col-md-6">
        <h2 class="h5">Alle boeken</h2>
        {% for book in books %}
            <div class="mb-3 p-2 bg-white border rounded">
                <strong>{{ book.title }}</strong> (ISBN: {{ book.isbn }})<br>
                <span class="text-muted">Auteurs:</span>
                <ul class="mb-0">
                    {% for author in book.authors %}
                        <li>{{ author.name }} – {{ author.country }}</li>
                    {% else %}
                        <li class="text-muted">Geen auteurs gekoppeld</li>
                    {% endfor %}
                </ul>
            </div>
        {% endfor %}
    </div>
    <div class="col-md-6">
        <h2 class="h5">Alle auteurs</h2>
        {% for author in authors %}
            <div class="mb-3 p-2 bg-white border rounded">
                <strong>{{ author.name }}</strong> ({{ author.country }})<br>
                <span class="text-muted">Boeken:</span>
                <ul class="mb-0">
                    {% for book in author.books %}
                        <li>{{ book.title }}</li>
                    {% else %}
                        <li class="text-muted">Geen boeken gekoppeld</li>
                    {% endfor %}
                </ul>
            </div>
        {% endfor %}
    </div>
</div>
{% endblock %}
