<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Relations oefening{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
</head>
<body class="bg-light">
<nav class="navbar navbar-dark bg-dark mb-4">
    <div class="container">
        <a class="navbar-brand" href="{{ path('app_home') }}">Relations &amp; Forms</a>
        <div class="navbar-nav flex-row gap-3">
            <a class="nav-link" href="{{ path('app_show_information_books') }}">MtM: Books</a>
            <a class="nav-link" href="{{ path('app_show_information_students') }}">MtM: Students</a>
            <a class="nav-link" href="{{ path('app_pizza_index') }}">Pizza form</a>
            <a class="nav-link" href="{{ path('app_customer_index') }}">Customer form</a>
        </div>
    </div>
</nav>
<main class="container pb-5">
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-success alert-dismissible fade show">{{ message }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
        {% endfor %}
    {% endfor %}
    {% block body %}{% endblock %}
</main>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
