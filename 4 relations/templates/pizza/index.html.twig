{% extends 'base.html.twig' %}
{% block title %}Pizza's{% endblock %}
{% block body %}
<div class="d-flex justify-content-between mb-3">
    <h1 class="h3">Pizza's</h1>
    <div>
        <a href="{{ path('app_pizza_new_simple') }}" class="btn btn-outline-secondary">Simple form</a>
        <a href="{{ path('app_pizza_new') }}" class="btn btn-warning">form_rows</a>
    </div>
</div>
<table class="table bg-white shadow-sm">
    <thead><tr><th>Naam</th><th>Prijs</th><th>Maat</th></tr></thead>
    <tbody>
    {% for pizza in pizzas %}
        <tr><td>{{ pizza.name }}</td><td>&euro; {{ pizza.price|number_format(2, ',', '.') }}</td><td>{{ pizza.size }}</td></tr>
    {% else %}
        <tr><td colspan="3" class="text-muted">Nog geen pizza's.</td></tr>
    {% endfor %}
    </tbody>
</table>
{% endblock %}
