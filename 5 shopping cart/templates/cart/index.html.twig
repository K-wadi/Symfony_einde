{% extends 'base.html.twig' %}

{% block title %}Winkelwagen{% endblock %}

{% block body %}
<h1 class="h3 mb-4"><i class="bi bi-cart3"></i> Winkelwagen</h1>

<div class="row">
    <div class="col-lg-8">
        {% if shoppingCart is empty %}
            <p class="alert alert-info">Je winkelwagen is leeg. <a href="{{ path('app_home') }}">Ga shoppen</a></p>
        {% else %}
            <div class="table-responsive bg-white shadow-sm rounded">
                <table class="table align-middle mb-0">
                    <thead class="table-primary">
                        <tr>
                            <th>Product</th>
                            <th>Prijs</th>
                            <th>Aantal</th>
                            <th>Totaal</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for line in shoppingCart %}
                        <tr>
                            <td>
                                <strong>{{ line.product.name }}</strong><br>
                                <small class="text-muted">{{ line.product.description|slice(0, 60) }}...</small>
                            </td>
                            <td>&euro; {{ line.product.price }}</td>
                            <td>
                                <div class="btn-group btn-group-sm">
                                    <a href="{{ path('app_cart_decrease', {id: line.product.id}) }}" class="btn btn-outline-secondary">−</a>
                                    <span class="btn btn-light disabled">{{ line.quantity }}</span>
                                    <a href="{{ path('app_cart_increase', {id: line.product.id}) }}" class="btn btn-outline-secondary">+</a>
                                </div>
                            </td>
                            <td>&euro; {{ line.lineTotal }}</td>
                            <td>
                                <form method="post" action="{{ path('app_cart_remove', {id: line.product.id}) }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('remove' ~ line.product.id) }}">
                                    <button class="btn btn-sm btn-danger"><i class="bi bi-trash"></i></button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                    <tfoot>
                        <tr>
                            <th colspan="3" class="text-end">Totaal</th>
                            <th colspan="2">&euro; {{ totalPrice }}</th>
                        </tr>
                    </tfoot>
                </table>
            </div>

            <form method="post" action="{{ path('app_cart_clear') }}" class="mt-3">
                <input type="hidden" name="_token" value="{{ csrf_token('clear_cart') }}">
                <button class="btn btn-outline-danger">Winkelwagen legen</button>
            </form>
        {% endif %}
    </div>

    <div class="col-lg-4">
        <div class="card shadow-sm">
            <div class="card-header bg-success text-white">Afrekenen</div>
            <div class="card-body">
                {{ form_start(checkoutForm) }}
                    {{ form_row(checkoutForm.customerName) }}
                    {{ form_row(checkoutForm.email) }}
                    {{ form_row(checkoutForm.save) }}
                {{ form_end(checkoutForm) }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
